  for(my $i=$#p;$i>=0;$i--){
    my $t=$p[$i];
    next if $t =~ /''^'"\\s*"'$/;
    next if $t =~ /''^'"\\s*\\\\end\\{/;
    "'$j=$i; last;
  }
  $j=$#p if $j<0;
  if($$eqref<=111 && $j>=0 && $p[$j] !~ /'"\\\\tag\\{/){
    chomp "'$p[$j];
    $p[$j] .= " '"\\\\tag{"'$$eqref}'"\\n\";
    "'$$eqref++;
  }
  push @$out,@p;
}

for my $line (@lines){
  if($line =~ /''^'"\\"'$'"\\"'$'"\\s*"'$/){
    if(!$inside){
      push @out,$line;
      $inside=1; @blk=();
    } else {
      flush_block('"\\@blk,\\@out,\\"'$eq);
      push @out,$line;
      $inside=0; @blk=();
    }
    next;
  }
  if($inside){ push @blk,$line; }
  else { push @out,$line; }
}
if($inside){ flush_block('"\\@blk,\\@out,\\"'$eq); }
open my $of,'"'>',"'$f or die $!; print {$of} @out; close $of;
