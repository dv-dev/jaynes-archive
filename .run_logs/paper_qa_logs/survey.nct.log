sub flush_block {
  my ($blk,$out,$eqref)=@_;
  my @b=@$blk;
  my @p;
  for my $l (@b){
    if($$eqref<=111 && $l =~ /'"\\\\\\\\/ && "'$l !~ /'"\\\\tag\\{/){
      "'$l =~ s/'"\\\\\\\\/ \\\\tag{"'$$eqref} '"\\\\\\\\/;
      "'$$eqref++;
    }
    push @p,$l;
  }
