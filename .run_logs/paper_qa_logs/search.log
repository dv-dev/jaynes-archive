171:$$p_D = 1 - \exp\left(-\frac{z+z^*}{S}\right) \tag{14}$$
175:$$z^* \equiv S[J(0) - J(z)] \tag{15}$$
207:$$\hat{z}_i^{(1)} + \hat{z}_i^{(2)} = \hat{z}_i, \quad 1 \le i \le n \tag{16}$$
235:$$p_j[1 - \exp(-\delta z/s_j)] = (p_j/s_j)\delta z \tag{18}$$
239:$$\delta p_i = (p_i - \delta_{ij})(p_j/s_j)\delta z \tag{19}$$
242:$$\delta I = [I + \log(p_j/m_j)](p_j/s_j)\delta z \tag{20}$$
244:$$\delta J = S^{-1}[1 - (p_j/m_j)]\delta z \tag{21}$$
284:$$a_i = p_i/m_i \tag{22}$$
