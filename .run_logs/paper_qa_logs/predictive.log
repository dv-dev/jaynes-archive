740:$$\hat{N}_i = N Z^{-1} \exp(-\beta E_i) \tag{10}$$
926:$$R_k = n^{-1} \sum_t y_t y_{t+k} \tag{11}$$
931:$$P(f) = \sum_{k=-n}^{n} R_k \cos(2\pi kf) \tag{12}$$
947:$$[P(f)]_{BT} = \sum_{k=-m}^{m} R_k W_k \cos(2\pi kf) \tag{13}$$
952:$$W_k = \frac{1}{2}(1 + \cos(\pi k/m)) \tag{14}$$
969:$$S = -\int p(y) \log p(y) d^n y \tag{15}$$
975:$$p(y) \propto \exp[-\sum_k \lambda_k R_k] \tag{16}$$
981:$$S = \int df \log P(f) \tag{17}$$
989:$$P(f) = (\sum_k \lambda_k \cos 2\pi kf)^{-1} \tag{18}$$
1089:$$NS(X) + \log L(X) \tag{19}$$
1096:$$L(X) = \exp \left\{ -\sum_k (d_k - m_k)^2 / 2h^2 \right\} \tag{20}$$
