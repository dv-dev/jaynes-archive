A_tags=set('A'+x for x in re.findall(r'\\\\tag\\{A([0-9]+)\\}',p))
# collect refs like (12), (A8)
num_refs=set(int(x) for x in re.findall(r'\\(([0-9]{1,2})\\)',p))
A_refs=set('A'+x for x in re.findall(r'\\((A[0-9]{1,2})\\)',p))
# likely non-eq numeric refs (years etc) filtered to <=51 already by regex len2
missing_num=sorted(n for n in num_refs if n not in num_tags)
missing_A=sorted(a for a in A_refs if a not in A_tags)
print('num_tags_range',min(num_tags),max(num_tags),len(num_tags))
print('A_tags',sorted(A_tags)[:3],sorted(A_tags)[-3:],len(A_tags))
print('missing_num',missing_num)
print('missing_A',missing_A)
